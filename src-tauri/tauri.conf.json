{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nuoruo_browser",
  "version": "0.1.0",
  "identifier": "com.mayiwen.nuoruo_browser",
  "build": {
    "beforeDevCommand": "trunk serve",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "trunk build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src *; script-src * 'unsafe-inline' 'unsafe-eval'; style-src * 'unsafe-inline'; img-src * data:; connect-src *;",
      "dangerousDisableAssetCspModification": true
    },
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "诺若浏览器",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "devtools": true,
        "label": "main"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
